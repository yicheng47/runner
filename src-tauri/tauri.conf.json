{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Runner",
  "version": "0.1.4",
  "identifier": "com.wycstudios.runner",
  "build": {
    "beforeDevCommand": "npm run tauri:before:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run tauri:before:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Runner",
        "width": 1440,
        "height": 900,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yicheng47/runner/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5NkQ3NDI5RkFFMUZFMjMKUldRai91SDZLWFJ0V2J5RXhaalIxMndBdXU4NmJtUUIyTnBYamhoSjlmeEs4SkJ5NW9xaC9vYlAK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "externalBin": ["binaries/runner-cli"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
