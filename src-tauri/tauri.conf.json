{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Runner",
  "version": "0.1.0",
  "identifier": "com.wycstudios.runner",
  "build": {
    "beforeDevCommand": "npm run tauri:before:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run tauri:before:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Runner",
        "width": 1440,
        "height": 900,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": true,
        "acceptFirstMouse": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yicheng47/runner/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNING_PUBLIC_KEY"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
