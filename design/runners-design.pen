                          "type": "text",
                          "id": "umWfV",
                          "fill": "#82AAFF",
                          "content": "   func main() {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "w62Qa1",
                          "fill": "#DCDCE0",
                          "content": "       http.HandleFunc(\"/\", func(w http.ResponseWriter, r *http.Request) {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "O1unV4",
                          "fill": "#DCDCE0",
                          "content": "           w.Write([]byte(\"hello\\n\"))",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "yG9kC",
