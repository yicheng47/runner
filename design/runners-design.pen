                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "sScAD",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "WXXRv",
                          "fill": "#9A9BA5",
                          "content": " cwd:   /Users/jason/go/src/github.com/yicheng47/runner",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "fVbjk",
                          "fill": "#9A9BA5",
                          "content": " model: claude-opus-4-7  ·  /model to change",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "I5rj7",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "G47pK",
                          "fill": "#39E5FF",
                          "content": "▶ help me write a tiny Go http server",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "s7Xqq",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "JMGNc",
                          "fill": "#DCDCE0",
                          "content": "⏺ Here's a minimal example. Drop this into main.go:",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Oeqyg",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "JckFv",
                          "fill": "#C792EA",
                          "content": "   package main",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "rYv0e",
                          "fill": "#C792EA",
                          "content": "   import \"net/http\"",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "l1svnu",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "rtjgY",
                          "fill": "#82AAFF",
                          "content": "   func main() {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "cNtJJ",
                          "fill": "#DCDCE0",
                          "content": "       http.HandleFunc(\"/\", func(w http.ResponseWriter, r *http.Request) {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "s2x4y9",
                          "fill": "#DCDCE0",
                          "content": "           w.Write([]byte(\"hello\\n\"))",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
