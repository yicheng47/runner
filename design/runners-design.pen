                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "z2xFcY",
                          "fill": "#82AAFF",
                          "content": "   func main() {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "o2jWC5",
                          "fill": "#DCDCE0",
                          "content": "       http.HandleFunc(\"/\", func(w http.ResponseWriter, r *http.Request) {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "XnUyn",
                          "fill": "#DCDCE0",
                          "content": "           w.Write([]byte(\"hello\\n\"))",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Qq3tG",
