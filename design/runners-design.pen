                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "wdpwI",
                          "fill": "#9A9BA5",
                          "content": " model: claude-opus-4-7  ·  /model to change",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "QqZ9V",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "C3026a",
                          "fill": "#39E5FF",
                          "content": "▶ help me write a tiny Go http server",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "sLY12",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "z7040L",
                          "fill": "#DCDCE0",
                          "content": "⏺ Here's a minimal example. Drop this into main.go:",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "U9wai",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "BGi0t",
                          "fill": "#C792EA",
                          "content": "   package main",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "HTuPT",
                          "fill": "#C792EA",
                          "content": "   import \"net/http\"",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "qufNj",
                          "fill": "#5A5C66",
                          "content": " ",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "pwc3y",
                          "fill": "#82AAFF",
                          "content": "   func main() {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "A7ctzs",
                          "fill": "#DCDCE0",
                          "content": "       http.HandleFunc(\"/\", func(w http.ResponseWriter, r *http.Request) {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LCJrn",
                          "fill": "#DCDCE0",
                          "content": "           w.Write([]byte(\"hello\\n\"))",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "xIkLI",
                          "fill": "#DCDCE0",
                          "content": "       })",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "nWlCs",
                          "fill": "#DCDCE0",
                          "content": "       http.ListenAndServe(\":8080\", nil)",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "IgLtE",
                          "fill": "#82AAFF",
                          "content": "   }",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "on50i",
                          "fill": "#5A5C66",
